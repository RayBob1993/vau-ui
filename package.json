{
  "name": "vau-ui",
  "version": "1.0.6",
  "license": "MIT",
  "repository": "https://github.com/RayBob1993/vau-ui.git",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "core:create-component": "node tools/create-core-component/cli.js",
    "serve": "vite",
    "build:app": "vue-tsc && vite build",
    "build:core": "pnpm --filter @vau/core build",
    "build:ui": "pnpm --filter @vau/ui build",
    "build:lib": "pnpm run build:core && pnpm run build:ui && vite build --config vite.lib.config.ts",
    "build": "pnpm run build:lib",
    "preview": "vite preview",
    "test": "vitest run",
    "lint:js": "eslint --fix",
    "lint": "pnpm lint:js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme-base": {
      "import": "./packages/themes/base/src/index.scss"
    }
  },
  "files": [
    "dist",
    "packages/themes/base/src",
    "package.json",
    "README.md"
  ],
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "22.17.1"
  },
  "peerDependencies": {
    "vue": ">=3.5.30",
    "zod": ">=4.3.6"
  },
  "devDependencies": {
    "ejs": "3.1.10",
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@stylistic/eslint-plugin": "5.9.0",
    "@types/node": "25.4.0",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "@vue/test-utils": "2.4.6",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/tsconfig": "0.8.1",
    "eslint": "9.39.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-vue": "10.8.0",
    "eslint-plugin-import": "2.32.0",
    "happy-dom": "20.8.3",
    "husky": "9.1.7",
    "lint-staged": "16.3.3",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.0.18",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.5",
    "sass-embedded": "1.97.3"
  }
}
