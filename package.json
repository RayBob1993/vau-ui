{
  "name": "vau-ui",
  "version": "1.0.79",
  "license": "MIT",
  "repository": "https://github.com/RayBob1993/vau-ui.git",
  "type": "module",
  "scripts": {
    "core:create-component": "node tools/create-core-component/cli.js",
    "serve": "vite",
    "build:lib": "vite build --config vite.lib.config.ts && vue-tsc -p tsconfig.build.json && node ./tools/rewrite-dts-import-aliases.mjs",
    "build": "pnpm run build:lib",
    "preview": "vite preview",
    "test": "vitest run",
    "lint:js": "eslint --fix",
    "lint": "pnpm lint:js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/lib/styles/core/index.scss",
    "./styles/config": "./src/lib/styles/core/config.scss",
    "./styles/mixins": "./src/lib/styles/core/mixins/index.scss"
  },
  "files": [
    "dist",
    "src/lib/styles/core",
    "package.json",
    "README.md"
  ],
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "22.17.1"
  },
  "peerDependencies": {
    "vue": ">=3.5.32",
    "zod": ">=4.3.6"
  },
  "devDependencies": {
    "ejs": "3.1.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@stylistic/eslint-plugin": "5.9.0",
    "@types/node": "25.5.2",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "@vue/test-utils": "2.4.6",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/tsconfig": "0.8.1",
    "eslint": "9.39.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-vue": "10.8.0",
    "eslint-plugin-import": "2.32.0",
    "happy-dom": "20.8.3",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "typescript": "6.0.2",
    "vite": "8.0.4",
    "vitest": "4.1.2",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.6",
    "sass-embedded": "1.99.0"
  }
}
