{
  "name": "vau",
  "version": "0.0.89",
  "license": "MIT",
  "type": "module",
  "description": "",
  "scripts": {
    "core:create-component": "node tools/create-core-component/cli.js",
    "serve": "vite",
    "build:lib": "vite build --config vite.lib.config.ts && vue-tsc -p tsconfig.build.json && node ./tools/rewrite-dts-import-aliases.mjs",
    "build": "pnpm run build:lib",
    "preview": "vite preview",
    "test": "vitest run",
    "lint:js": "eslint --fix",
    "lint": "pnpm lint:js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RayBob1993/vau.git",
    "directory": "src/lib"
  },
  "bugs": {
    "url": "https://github.com/RayBob1993/vau/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json",
    "./styles": "./src/lib/styles/core/index.scss",
    "./styles/config": "./src/lib/styles/core/config.scss",
    "./styles/mixins": "./src/lib/styles/core/mixins/index.scss"
  },
  "keywords": [
    "vue ui",
    "vau ui",
    "components",
    "vue components",
    "accordion",
    "avatar",
    "toast",
    "dialog",
    "modal",
    "form",
    "switch",
    "button",
    "confirm",
    "alert",
    "checkbox",
    "radio",
    "grid",
    "primitive",
    "scrollbar",
    "spinner",
    "tag",
    "text",
    "input",
    "divider",
    "calendar",
    "badge",
    "input code",
    "input number",
    "input password",
    "input range",
    "input tags"
  ],
  "files": [
    "dist",
    "src/lib/styles/core",
    "package.json"
  ],
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "22.17.1"
  },
  "peerDependencies": {
    "vue": ">=3.5.33",
    "zod": ">=4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@stylistic/eslint-plugin": "5.9.0",
    "@types/node": "25.5.2",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.8.1",
    "ejs": "3.1.10",
    "eslint": "9.39.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-vue": "10.8.0",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "sass-embedded": "1.99.0",
    "typescript": "6.0.2",
    "vite": "8.0.10",
    "vitepress": "1.6.4",
    "vitest": "4.1.5",
    "vue": "3.5.33",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.7"
  }
}
