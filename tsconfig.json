{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,
    "newLine": "LF",

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": [
      "vitest/globals",
      "@types/node"
    ],

    // Path mapping (без baseUrl — см. миграцию TypeScript 6.0)
    "paths": {
      "@vau/core": ["./src/lib/core/index.ts"],
      "@vau/ui": ["./src/lib/ui/index.ts"]
    },

    "jsx": "preserve"
  },
  "include": [
    "src/**/*"
  ],
  "vueCompilerOptions": {
    "target": 3.5
  }
}
