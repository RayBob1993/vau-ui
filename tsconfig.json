{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,
    "newLine": "LF",

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["vitest/globals"],

    // Path mapping
    "baseUrl": ".",
    "paths": {
      "@vau/core": ["./src/lib/core/index.ts"],
      "@vau/ui": ["./src/lib/ui/index.ts"]
    },

    "jsx": "preserve"
  },
  "include": [
    "vue-global.d.ts",
    "src/**/*",
    "eslint.config.ts",
    "vitest.config.ts",
    "vite.config.ts",
    "vite.lib.config.ts"
  ]
}